# Copy to Backend/.env (or use a .env in the project root with the same keys).
# Never commit .env with real passwords.
#
# Supported names (either style works):
#   DB_HOST / DB_USER / DB_PASSWORD / DB_PORT
#   MYSQL_HOST / MYSQL_USER / MYSQL_PASSWORD / MYSQL_PORT
#
# Database is always air_pollution (see schema.sql). DB_NAME / MYSQL_DATABASE in .env are ignored.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root123

# Optional: override API port (default 3000)
# PORT=3000
